# Decision Court — local dev env. Copy to .env and fill in. .env is gitignored.

# Groq API key — get a project key from https://console.groq.com
GROQ_API_KEY=gsk_replace_me

# Database (docker-compose provides this Postgres by default)
DATABASE_URL=postgresql+asyncpg://decisioncourt:decisioncourt@localhost:5432/decisioncourt

# Models (verify IDs against https://console.groq.com/docs — they change)
MODEL_DEBATE=llama-3.3-70b-versatile
MODEL_VERDICT=openai/gpt-oss-120b
MODEL_DEV=llama-3.1-8b-instant

# Set true to force every turn (incl. verdict) onto the cheap/instant dev model
DEV_MODE=false

# Cost guardrails
MAX_TOKENS_PER_TURN=900
MAX_TOKENS_PER_SESSION=40000
MAX_JUDGE_QUESTIONS=5

# Session-creation rate limit, per client IP
RATE_LIMIT_SESSIONS=20
RATE_LIMIT_WINDOW_SEC=3600

# Misc
CORS_ORIGINS=http://localhost:5173
CRISIS_REGION=US
# Absolute base URL — used for OG image links AND the OAuth redirect URI
PUBLIC_BASE_URL=http://localhost:8000
GALLERY_SIZE=24

# Auth (Google OAuth optional — leave blank to run guest-only locally)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=dev-insecure-change-me
COOKIE_SECURE=false
MEMORY_MAX_DECISIONS=5
